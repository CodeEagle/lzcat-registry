{
  "repo": "CodeEagle/cutia",
  "enabled": true,
  "upstream_repo": "msgbyte/cutia",
  "check_strategy": "commit_sha",
  "build_strategy": "upstream_with_target_template",
  "publish_to_store": false,
  "official_image_registry": "",
  "precompiled_binary_url": "",
  "dockerfile_type": "custom",
  "dockerfile_path": "Dockerfile.template",
  "build_context": ".",
  "service_port": 3000,
  "service_cmd": [
    "cutia"
  ],
  "image_targets": [
    "cutia"
  ],
  "dependencies": [
    {
      "target_service": "postgres",
      "source_image": "postgres:16-alpine"
    },
    {
      "target_service": "redis",
      "source_image": "redis:7-alpine"
    }
  ]
}
